@keyframes lt-shineSkeletonCards {=20
  0% { background-position: -620px center; }
  100% { background-position: 620px center; }
}

@keyframes lt-loadingBar {=20
  0% { transform: translateX(0%); }
  100% { transform: translateX(200%); }
}

@keyframes lt-pulse {=20
  0% { box-shadow: transparent 0px 0px 0px 2px; }
  50% { box-shadow: rgb(35, 154, 255) 0px 0px 0px 2px; }
  100% { box-shadow: transparent 0px 0px 0px 2px; }
}

@keyframes lt-pulse-fade {=20
  0% { background-color: rgb(35, 154, 255); }
  50% { background-color: var(--lt-color-white); }
  100% { background-color: rgb(35, 154, 255); }
}

@keyframes lt-wave {=20
  100% { transform: translateX(-50%); }
}

@keyframes lt-fadein {=20
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes lt-fadein-delay {=20
  0% { opacity: 0; }
  50% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes lt-appear {=20
  0% { transform: translateX(0px); }
  100% { transform: translateX(-6px); }
}

@keyframes lt-rotate {=20
  0% { transform: rotate(0deg); }
  100% { transform: rotate(-360deg); }
}

